local Framework = require("../framework")
local describe = Framework.describe
local it = Framework.it
local expect = Framework.expect

local KnifeStateMachine = require("./KnifeStateMachine")

return function()
	describe("KnifeStateMachine.new", function()
		it("initializes with all flags false", function()
			local state = KnifeStateMachine.new()
			expect(state.isStabbing):toBe(false)
			expect(state.isThrowing):toBe(false)
		end)

		it("returns a fresh table each call", function()
			local a = KnifeStateMachine.new()
			local b = KnifeStateMachine.new()
			expect(a ~= b):toBe(true)
		end)

		it("does not share state between instances", function()
			local a = KnifeStateMachine.new()
			local b = KnifeStateMachine.new()
			KnifeStateMachine.setActionActive(a, "Stab")
			expect(b.isStabbing):toBe(false)
		end)

		it("has exactly two keys", function()
			local state = KnifeStateMachine.new()
			local count = 0
			for _ in state do
				count += 1
			end
			expect(count):toBe(2)
		end)
	end)

	describe("KnifeStateMachine.isLocked", function()
		it("returns false when idle", function()
			local state = KnifeStateMachine.new()
			expect(KnifeStateMachine.isLocked(state)):toBe(false)
		end)

		it("returns true when stabbing", function()
			local state = KnifeStateMachine.new()
			KnifeStateMachine.setActionActive(state, "Stab")
			expect(KnifeStateMachine.isLocked(state)):toBe(true)
		end)

		it("returns true when throwing", function()
			local state = KnifeStateMachine.new()
			KnifeStateMachine.setActionActive(state, "Throw")
			expect(KnifeStateMachine.isLocked(state)):toBe(true)
		end)

		it("returns false after reset from stabbing", function()
			local state = KnifeStateMachine.new()
			KnifeStateMachine.setActionActive(state, "Stab")
			KnifeStateMachine.resetAction(state, "Stab")
			expect(KnifeStateMachine.isLocked(state)):toBe(false)
		end)

		it("returns false after reset from throwing", function()
			local state = KnifeStateMachine.new()
			KnifeStateMachine.setActionActive(state, "Throw")
			KnifeStateMachine.resetAction(state, "Throw")
			expect(KnifeStateMachine.isLocked(state)):toBe(false)
		end)

		it("returns false after resetAll", function()
			local state = KnifeStateMachine.new()
			KnifeStateMachine.setActionActive(state, "Stab")
			KnifeStateMachine.resetAll(state)
			expect(KnifeStateMachine.isLocked(state)):toBe(false)
		end)

		it("remains locked after failed unknown action on locked state", function()
			local state = KnifeStateMachine.new()
			KnifeStateMachine.setActionActive(state, "Stab")
			KnifeStateMachine.setActionActive(state, "Unknown")
			expect(KnifeStateMachine.isLocked(state)):toBe(true)
		end)
	end)

	describe("KnifeStateMachine.setActionActive", function()
		it("accepts stab when idle", function()
			local state = KnifeStateMachine.new()
			local accepted = KnifeStateMachine.setActionActive(state, "Stab")
			expect(accepted):toBe(true)
			expect(state.isStabbing):toBe(true)
			expect(state.isThrowing):toBe(false)
		end)

		it("accepts throw when idle", function()
			local state = KnifeStateMachine.new()
			local accepted = KnifeStateMachine.setActionActive(state, "Throw")
			expect(accepted):toBe(true)
			expect(state.isThrowing):toBe(true)
			expect(state.isStabbing):toBe(false)
		end)

		it("rejects stab when already stabbing", function()
			local state = KnifeStateMachine.new()
			KnifeStateMachine.setActionActive(state, "Stab")
			local accepted = KnifeStateMachine.setActionActive(state, "Stab")
			expect(accepted):toBe(false)
		end)

		it("rejects throw when stabbing", function()
			local state = KnifeStateMachine.new()
			KnifeStateMachine.setActionActive(state, "Stab")
			local accepted = KnifeStateMachine.setActionActive(state, "Throw")
			expect(accepted):toBe(false)
		end)

		it("rejects stab when throwing", function()
			local state = KnifeStateMachine.new()
			KnifeStateMachine.setActionActive(state, "Throw")
			local accepted = KnifeStateMachine.setActionActive(state, "Stab")
			expect(accepted):toBe(false)
		end)

		it("rejects throw when already throwing", function()
			local state = KnifeStateMachine.new()
			KnifeStateMachine.setActionActive(state, "Throw")
			local accepted = KnifeStateMachine.setActionActive(state, "Throw")
			expect(accepted):toBe(false)
		end)

		it("rejects unknown action", function()
			local state = KnifeStateMachine.new()
			local accepted = KnifeStateMachine.setActionActive(state, "Unknown")
			expect(accepted):toBe(false)
			expect(state.isStabbing):toBe(false)
			expect(state.isThrowing):toBe(false)
		end)

		it("rejects empty string action", function()
			local state = KnifeStateMachine.new()
			local accepted = KnifeStateMachine.setActionActive(state, "")
			expect(accepted):toBe(false)
			expect(KnifeStateMachine.isLocked(state)):toBe(false)
		end)

		it("rejects case-variant 'stab' (lowercase)", function()
			local state = KnifeStateMachine.new()
			local accepted = KnifeStateMachine.setActionActive(state, "stab")
			expect(accepted):toBe(false)
		end)

		it("rejects case-variant 'THROW' (uppercase)", function()
			local state = KnifeStateMachine.new()
			local accepted = KnifeStateMachine.setActionActive(state, "THROW")
			expect(accepted):toBe(false)
		end)

		it("rejects action with whitespace padding", function()
			local state = KnifeStateMachine.new()
			local accepted = KnifeStateMachine.setActionActive(state, " Stab ")
			expect(accepted):toBe(false)
		end)

		it("does not mutate state on unknown action", function()
			local state = KnifeStateMachine.new()
			KnifeStateMachine.setActionActive(state, "Slash")
			expect(state.isStabbing):toBe(false)
			expect(state.isThrowing):toBe(false)
		end)

		it("does not mutate state on rejected duplicate", function()
			local state = KnifeStateMachine.new()
			KnifeStateMachine.setActionActive(state, "Stab")
			KnifeStateMachine.setActionActive(state, "Stab")
			expect(state.isStabbing):toBe(true)
			expect(state.isThrowing):toBe(false)
		end)
	end)

	describe("KnifeStateMachine.resetAction", function()
		it("resets stab flag only", function()
			local state = KnifeStateMachine.new()
			KnifeStateMachine.setActionActive(state, "Stab")
			KnifeStateMachine.resetAction(state, "Stab")
			expect(state.isStabbing):toBe(false)
		end)

		it("resets throw flag only", function()
			local state = KnifeStateMachine.new()
			KnifeStateMachine.setActionActive(state, "Throw")
			KnifeStateMachine.resetAction(state, "Throw")
			expect(state.isThrowing):toBe(false)
		end)

		it("allows new action after reset", function()
			local state = KnifeStateMachine.new()
			KnifeStateMachine.setActionActive(state, "Stab")
			KnifeStateMachine.resetAction(state, "Stab")
			local accepted = KnifeStateMachine.setActionActive(state, "Throw")
			expect(accepted):toBe(true)
			expect(state.isThrowing):toBe(true)
		end)

		it("allows same action again after reset", function()
			local state = KnifeStateMachine.new()
			KnifeStateMachine.setActionActive(state, "Stab")
			KnifeStateMachine.resetAction(state, "Stab")
			local accepted = KnifeStateMachine.setActionActive(state, "Stab")
			expect(accepted):toBe(true)
			expect(state.isStabbing):toBe(true)
		end)

		it("resetting wrong action does not unlock", function()
			local state = KnifeStateMachine.new()
			KnifeStateMachine.setActionActive(state, "Stab")
			KnifeStateMachine.resetAction(state, "Throw")
			expect(KnifeStateMachine.isLocked(state)):toBe(true)
			expect(state.isStabbing):toBe(true)
		end)

		it("resetting idle state is a no-op", function()
			local state = KnifeStateMachine.new()
			KnifeStateMachine.resetAction(state, "Stab")
			expect(state.isStabbing):toBe(false)
			expect(state.isThrowing):toBe(false)
		end)

		it("resetting unknown action does not error", function()
			local state = KnifeStateMachine.new()
			KnifeStateMachine.resetAction(state, "Explode")
			expect(state.isStabbing):toBe(false)
			expect(state.isThrowing):toBe(false)
		end)

		it("double reset does not error", function()
			local state = KnifeStateMachine.new()
			KnifeStateMachine.setActionActive(state, "Stab")
			KnifeStateMachine.resetAction(state, "Stab")
			KnifeStateMachine.resetAction(state, "Stab")
			expect(state.isStabbing):toBe(false)
		end)
	end)

	describe("KnifeStateMachine.resetAll", function()
		it("resets all flags from stabbing", function()
			local state = KnifeStateMachine.new()
			KnifeStateMachine.setActionActive(state, "Stab")
			KnifeStateMachine.resetAll(state)
			expect(state.isStabbing):toBe(false)
			expect(state.isThrowing):toBe(false)
		end)

		it("resets all flags from throwing", function()
			local state = KnifeStateMachine.new()
			KnifeStateMachine.setActionActive(state, "Throw")
			KnifeStateMachine.resetAll(state)
			expect(state.isStabbing):toBe(false)
			expect(state.isThrowing):toBe(false)
		end)

		it("allows action after resetAll", function()
			local state = KnifeStateMachine.new()
			KnifeStateMachine.setActionActive(state, "Throw")
			KnifeStateMachine.resetAll(state)
			local accepted = KnifeStateMachine.setActionActive(state, "Stab")
			expect(accepted):toBe(true)
		end)

		it("resetAll on idle state is a no-op", function()
			local state = KnifeStateMachine.new()
			KnifeStateMachine.resetAll(state)
			expect(state.isStabbing):toBe(false)
			expect(state.isThrowing):toBe(false)
			expect(KnifeStateMachine.isLocked(state)):toBe(false)
		end)

		it("double resetAll does not error", function()
			local state = KnifeStateMachine.new()
			KnifeStateMachine.setActionActive(state, "Stab")
			KnifeStateMachine.resetAll(state)
			KnifeStateMachine.resetAll(state)
			expect(KnifeStateMachine.isLocked(state)):toBe(false)
		end)
	end)

	describe("KnifeStateMachine.serialize", function()
		it("returns a copy not the original", function()
			local state = KnifeStateMachine.new()
			KnifeStateMachine.setActionActive(state, "Stab")
			local serialized = KnifeStateMachine.serialize(state)
			expect(serialized.isStabbing):toBe(true)
			serialized.isStabbing = false
			expect(state.isStabbing):toBe(true)
		end)

		it("copies both fields", function()
			local state = KnifeStateMachine.new()
			local serialized = KnifeStateMachine.serialize(state)
			expect(serialized.isStabbing):toBe(false)
			expect(serialized.isThrowing):toBe(false)
		end)

		it("reflects throwing state", function()
			local state = KnifeStateMachine.new()
			KnifeStateMachine.setActionActive(state, "Throw")
			local serialized = KnifeStateMachine.serialize(state)
			expect(serialized.isStabbing):toBe(false)
			expect(serialized.isThrowing):toBe(true)
		end)

		it("modifying serialized copy does not affect original (throw)", function()
			local state = KnifeStateMachine.new()
			KnifeStateMachine.setActionActive(state, "Throw")
			local serialized = KnifeStateMachine.serialize(state)
			serialized.isThrowing = false
			expect(state.isThrowing):toBe(true)
		end)

		it("each serialize call returns a distinct table", function()
			local state = KnifeStateMachine.new()
			local s1 = KnifeStateMachine.serialize(state)
			local s2 = KnifeStateMachine.serialize(state)
			expect(s1 ~= s2):toBe(true)
		end)

		it("serialize after resetAll returns idle state", function()
			local state = KnifeStateMachine.new()
			KnifeStateMachine.setActionActive(state, "Stab")
			KnifeStateMachine.resetAll(state)
			local serialized = KnifeStateMachine.serialize(state)
			expect(serialized.isStabbing):toBe(false)
			expect(serialized.isThrowing):toBe(false)
		end)
	end)

	describe("KnifeStateMachine full lifecycle", function()
		it("stab -> reset -> throw -> reset works", function()
			local state = KnifeStateMachine.new()
			expect(KnifeStateMachine.setActionActive(state, "Stab")):toBe(true)
			KnifeStateMachine.resetAction(state, "Stab")
			expect(KnifeStateMachine.setActionActive(state, "Throw")):toBe(true)
			KnifeStateMachine.resetAction(state, "Throw")
			expect(KnifeStateMachine.isLocked(state)):toBe(false)
		end)

		it("throw -> reset -> stab -> reset works", function()
			local state = KnifeStateMachine.new()
			expect(KnifeStateMachine.setActionActive(state, "Throw")):toBe(true)
			KnifeStateMachine.resetAction(state, "Throw")
			expect(KnifeStateMachine.setActionActive(state, "Stab")):toBe(true)
			KnifeStateMachine.resetAction(state, "Stab")
			expect(KnifeStateMachine.isLocked(state)):toBe(false)
		end)

		it("rapid alternating actions with resets all succeed", function()
			local state = KnifeStateMachine.new()
			for _ = 1, 50 do
				expect(KnifeStateMachine.setActionActive(state, "Stab")):toBe(true)
				KnifeStateMachine.resetAction(state, "Stab")
				expect(KnifeStateMachine.setActionActive(state, "Throw")):toBe(true)
				KnifeStateMachine.resetAction(state, "Throw")
			end
			expect(KnifeStateMachine.isLocked(state)):toBe(false)
		end)

		it("rapid same action spam all rejected after first", function()
			local state = KnifeStateMachine.new()
			expect(KnifeStateMachine.setActionActive(state, "Stab")):toBe(true)
			for _ = 1, 20 do
				expect(KnifeStateMachine.setActionActive(state, "Stab")):toBe(false)
				expect(KnifeStateMachine.setActionActive(state, "Throw")):toBe(false)
			end
			expect(state.isStabbing):toBe(true)
			expect(state.isThrowing):toBe(false)
		end)

		it("resetAll mid-action allows immediate re-action", function()
			local state = KnifeStateMachine.new()
			KnifeStateMachine.setActionActive(state, "Stab")
			KnifeStateMachine.resetAll(state)
			expect(KnifeStateMachine.setActionActive(state, "Stab")):toBe(true)
		end)

		it("many states are independent", function()
			local states = {}
			for i = 1, 10 do
				states[i] = KnifeStateMachine.new()
			end
			KnifeStateMachine.setActionActive(states[1], "Stab")
			KnifeStateMachine.setActionActive(states[5], "Throw")
			for i = 2, 4 do
				expect(KnifeStateMachine.isLocked(states[i])):toBe(false)
			end
			for i = 6, 10 do
				expect(KnifeStateMachine.isLocked(states[i])):toBe(false)
			end
			expect(KnifeStateMachine.isLocked(states[1])):toBe(true)
			expect(KnifeStateMachine.isLocked(states[5])):toBe(true)
		end)
	end)

	Framework.summary()
end
